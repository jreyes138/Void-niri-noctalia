# Void Linux dotfiles
# Files that contain secrets or machine-specific paths
.config/ghostty/themes/
.config/micro/colorschemes/catppuccin-*
.config/bat/themes/*.tmTheme
.config/yazi/flavors/

# Noctalia state (generated by Noctalia at runtime)
.config/noctalia/state.toml

# Git credentials
.gitconfig
.ssh/

# Cache and temp files
*.bak
*.log
.DS_Store
__pycache__/
*.pyc

# Vim/nvim generated
.local/share/nvim/
.local/state/nvim/
.cache/